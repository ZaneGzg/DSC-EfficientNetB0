def create_ablation_models(input_shape=(224, 224, 3), num_classes=10):
    models_config = {
        'EfficientNetB0': create_improved_efficientnet(input_shape=input_shape, num_classes=num_classes,use_dca=False, use_sdc=False, use_can=False) 
